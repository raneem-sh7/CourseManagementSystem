@{
}
@model IEnumerable<CourseManagementSystem.Models.Course>

<head>
    <style>
            table, th, td {
              border: 1px solid black;
            }
    </style>
</head>

<h1>Courses</h1>
<table style="width:100%">
    <thead>
        <tr>

            <th>Course Name</th>
            <th>Subject</th>
            <th>Section</th>
            <th>Teacher Name</th>
            <th>Duration</th>
        </tr>
    </thead>
    
    <tbody>
        
            @foreach (var item in Model)
            {
             <tr>

                 <td>@item.CourseName</td>
                 <td>@item.Subject</td>
                 <td>@item.Teachear.TeacherName</td>
                 <td>@item.Section.SectionName</td>
                 <td>@item.Duration</td>

             </tr>   

            }

        
    </tbody>
    
</table>

