    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model IEnumerable<CourseManagementSystem.Models.Student>

<h1>Students</h1>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Country</th>
            <th>Age</th>
            <th>Email</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <thead>
                
                <td>@item.StudentName</td>
                <td>@item.Country</td>
                <td>@item.Age</td>
                <td>@item.Email</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.StudentId">
                        Edit
                    </a>
                </td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@item.StudentId">
                            Delete
                        </a>
                    </td>
                </thead>
                
            </tr>
            
        }
        
    </tbody>
    
</table>
<td>
    <a asp-action="Create">
        <button type="submit"> Create A New Student</button>
    </a>
</td>