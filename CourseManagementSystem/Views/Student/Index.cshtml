@{
}
@model IEnumerable<CourseManagementSystem.Models.Student>

<h1>Students</h1>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Country</th>
            <th>Age</th>
            <th>Email</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentName</td>
                <td>@item.Country</td>
                <td>@item.Age</td>
                <td>@item.Email</td>
            </tr>
        }
    </tbody>
</table>